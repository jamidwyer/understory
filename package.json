{
  "name": "understory",
  "version": "1.0.0",
  "description": "Component catalog for @jamidwyer/understory-web-components — browse every component with live examples and copyable HTML snippets",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run copy:components",
    "copy:components": "mkdir -p public/vendor && cp node_modules/@jamidwyer/understory-web-components/dist/index.esm.js public/vendor/understory-web-components.js",
    "start": "node dist/server.js",
    "dev": "npm run build && node dist/server.js"
  },
  "license": "MIT",
  "author": "jamidwyer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamidwyer/understory.git"
  },
  "homepage": "https://github.com/jamidwyer/understory#readme",
  "bugs": {
    "url": "https://github.com/jamidwyer/understory/issues"
  },
  "dependencies": {
    "@jamidwyer/understory-web-components": "file:../simple-components",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "typescript": "^5.5.3"
  }
}
